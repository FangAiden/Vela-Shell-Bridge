local lvgl    = require("lvgl")
local Toast   = require("Toast")
local json    = require("json")
local math    = require("math")

local screen_w = lvgl.HOR_RES()
local screen_h = lvgl.VER_RES()
local SAFE_SIDE_LENGTH = math.sqrt(2) * (lvgl.HOR_RES() / 2)

local root    = lvgl.Object(nil, {
    w = screen_w,
    h = screen_h,
    bg_color = "#000000",
    border_width = 0,
}):add_flag(lvgl.FLAG.EVENT_BUBBLE)

local safeBox = lvgl.Object(root, {
    w = SAFE_SIDE_LENGTH,
    h = SAFE_SIDE_LENGTH,
    bg_color = "#001A30",
    text_color = "#C8C8C8",
    font_size = 18,
    align = lvgl.ALIGN.CENTER
})

local title = lvgl.Label(root, {
    text  = "Shell Bridge",
    align = lvgl.ALIGN and lvgl.ALIGN.TOP_MID or nil,
})
title:set {
    text_color = 0xDDDDDD,
    y = 6,
}