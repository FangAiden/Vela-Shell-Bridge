  color: #f2f2f2;
  font-size: 12px;
  font-weight: 800;
}

.blank {
  height: 120px;
}

/* 文本行数控制（text 组件是 style 属性，不是 attribute） */
.lines-1 {
  lines: 1;
  text-overflow: ellipsis;
}

.lines-2 {
  lines: 2;
  text-overflow: ellipsis;
}

.lines-3 {
  lines: 3;
  text-overflow: ellipsis;
}

/* —— 黑名单弹窗 —— */
.modal-mask {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.55);
  justify-content: center;
  align-items: center;
  transform-origin: center center;
}

.modal {
  width: 78%;
  height: 64%;
  border-radius: 18px;
  background-color: rgba(25, 25, 25, 0.98);
  flex-direction: column;
