/* —— 输入法 —— */
.ime-layer {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.88);
  z-index: 999;
  flex-direction: column;
  justify-content: flex-start;
  align-items: center;
}

.ime-header {
  width: 100%;
  height: 40px;
  flex-direction: row;
  justify-content: center;
  align-items: center;
  position: relative;
}

.ime-title {
  color: #f2f2f2;
  font-size: 16px;
  font-weight: 700;
}

.ime-close {
  position: absolute;
  right: 16px;
  top: 6px;
  padding: 6px 10px;
  border-radius: 12px;
  background-color: #1a1a1a;
  border-width: 1px;
  border-color: #2a2a2a;
}

.ime-close-text {
  color: #cccccc;
  font-size: 14px;
}

.ime-confirm {
  position: absolute;
  left: 16px;
  top: 6px;
  padding: 6px 10px;
  border-radius: 12px;
  background-color: #1f3323;
  border-width: 1px;
  border-color: #2d5a3a;
}

.ime-confirm-text {
  color: #a7f3c3;
  font-size: 14px;
}

.ime-preview {
  width: 88%;
  min-height: 36px;
  margin: 6px 0 4px;
  padding: 6px 10px;
  border-radius: 12px;
  background-color: #111111;
  border-width: 1px;
  border-color: #2a2a2a;
  align-items: flex-start;
  justify-content: center;
}

.ime-preview-text {
  color: #e6e6e6;
  font-size: 14px;
  lines: 2;
  text-overflow: ellipsis;
}

/* —— 页面动画 —— */
.page-anim {
  opacity: 0;
  transform: scale(0.8);
  transform-origin: center center;
}

.page-static {
  opacity: 1;
  transform: scale(1);
}

.page-enter {
  animation-name: pageIn;
  animation-duration: 220ms;
  animation-timing-function: cubic-bezier(0.33, 0.81, 0.55, 1.0);
  animation-iteration-count: 1;
}

.page-leave {
  animation-name: pageOut;
  animation-duration: 180ms;
  animation-timing-function: cubic-bezier(0.33, 0.81, 0.55, 1.0);
  animation-iteration-count: 1;
}

@keyframes pageIn {
  0% { opacity: 0; transform: scale(0.8); }
  100% { opacity: 1; transform: scale(1); }
}

@keyframes pageOut {
  0% { opacity: 1; transform: scale(1); }
  100% { opacity: 0; transform: scale(0.8); }
}

/* 弹窗动画 */
.modal-enter {
  animation-name: modalIn;
  animation-duration: 180ms;
  animation-timing-function: cubic-bezier(0.33, 0.81, 0.55, 1);
  animation-iteration-count: 1;
  animation-fill-mode: forwards;
}

.modal-leave {
  animation-name: modalOut;
  animation-duration: 180ms;
  animation-timing-function: cubic-bezier(0.33, 0.81, 0.55, 1);
  animation-iteration-count: 1;
  animation-fill-mode: forwards;
}

@keyframes modalIn {
  0% { opacity: 0; transform: scale(0.92); }
  100% { opacity: 1; transform: scale(1); }
}

@keyframes modalOut {
  0% { opacity: 1; transform: scale(1); }
  100% { opacity: 0; transform: scale(0.92); }
}
</style>
