  padding: 12px 12px;
}

.modal-title {
  color: #ffffff;
  font-size: 16px;
  font-weight: 900;
  text-align: center;
}

.modal-sub {
  color: #7a7a7a;
  font-size: 12px;
  text-align: center;
  margin-top: 4px;
  margin-bottom: 8px;
}

.form {
  width: 100%;
