    },
    {
      "name": "system.device"
    },
    {
      "name": "system.network"
    },
    {
      "name": "system.interconnect"
    },
    {
      "name": "system.audio"
    },
    {
      "name": "system.brightness"
    },
    {
      "name": "system.vibrator"
    },
    {
      "name": "system.geolocation"
    },
    {
      "name": "system.sensor"
    },
    {
      "name": "system.battery"
    },
    {
      "name": "system.volume"
    },
    {
      "name": "system.configuration"
    },
    {
      "name": "system.prompt"
    },
    {
      "name": "system.app"
    }
  ],
